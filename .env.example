PORT=5000
MONGO_URI=mongodb+srv://<user>:<password>@<cluster-url>/attendanceDB?retryWrites=true&w=majority
JWT_SECRET=<generate a long random string>
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173,https://attendance-system-frontend.vercel.app

GOOGLE_MAPS_KEY=<your Google Maps API key>

# Web Push (generate with `npx web-push generate-vapid-keys`)
VAPID_PUBLIC_KEY=<public key>
VAPID_PRIVATE_KEY=<private key>
VAPID_SUBJECT=mailto:<contact email>

# Used once by seedAdmin.js to create the first manager account
ADMIN_NAME=Admin
ADMIN_PHONE=9999999999
ADMIN_PASSWORD=<set a real temp password>
ADMIN_DEPARTMENT=Operations
